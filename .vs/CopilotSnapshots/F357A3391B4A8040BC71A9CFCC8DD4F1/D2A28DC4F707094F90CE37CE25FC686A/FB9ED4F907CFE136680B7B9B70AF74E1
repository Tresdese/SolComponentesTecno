<Window x:Class="WPFComponenteCombo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFComponenteCombo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="Aquamarine">
        <Label Content="Sistema operatvo" HorizontalAlignment="Left" Margin="130,126,0,280"/>
        <ComboBox Width="388" VerticalAlignment="Top" Margin="250,130,430,284">
            <ComboBoxItem Content="Windows 10"/>
            <ComboBoxItem Content="Windows 11"/>
            <ComboBoxItem Content="Linux"/>
        </ComboBox>
        <Label Content="Procesador" HorizontalAlignment="Left" Margin="130,176,0,230"/>
        <ComboBox x:Name="cb_procesador" Width="388" VerticalAlignment="Top"  Margin="250,180,430,230"/>
        <Label Content="Marca" HorizontalAlignment="Left" Margin="130,226,0,180"/>
        <ComboBox Width="388" VerticalAlignment="Top" Margin="250,229,162,0">
            <ComboBoxItem>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/icons8-dell-48.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Margin="15,0,0,0" Foreground="Black" FontWeight="Bold" VerticalAlignment="Center">DEll</TextBlock>
                </StackPanel>
            </ComboBoxItem>
            <ComboBoxItem>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/icons8-asus-64.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Margin="15,0,0,0" Foreground="Black" FontWeight="Bold" VerticalAlignment="Center">Asus</TextBlock>
                </StackPanel>
            </ComboBoxItem>
            <ComboBoxItem>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/icons8-hp-50.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Margin="15,0,0,0" Foreground="Black" FontWeight="Bold" VerticalAlignment="Center">HP</TextBlock>
                </StackPanel>
            </ComboBoxItem>
            <ComboBoxItem>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/icons8-lenovo-48.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Margin="15,0,0,0" Foreground="Black" FontWeight="Bold" VerticalAlignment="Center">Lenovo</TextBlock>
                </StackPanel>
            </ComboBoxItem>
            <ComboBoxItem>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/icons8-mac-os-50.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Margin="15,0,0,0" Foreground="Black" FontWeight="Bold" VerticalAlignment="Center">Mac</TextBlock>
                </StackPanel>
            </ComboBoxItem>
        </ComboBox>
        <Label Content="Memoria RAM" HorizontalAlignment="Left" Margin="130,276,0,130"/>
        <ComboBox Width="388" VerticalAlignment="Top" Margin="250,280,430,130"/>
        <Label Content="Almacenamiento" HorizontalAlignment="Left" Margin="130,326,0,80"/>
        <TextBlock Text="SSD" HorizontalAlignment="Left" Margin="250,330,0,80"/>
        <Button HorizontalAlignment="Left" Margin="325,328,0,82" Width="75">
            <StackPanel>
                <Image Source="/img/icons8-agregar-48.png" Stretch="None"/>
                <TextBlock Text="Agregar" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
